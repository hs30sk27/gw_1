08002668 <prv_build_snapshot_payload.constprop.0>:
    /* payload timestamp는 현재/저장 epoch를 설정 문자열 기준 absolute epoch floor로 정렬한다.
     * 05M -> 00/05/10..., 10M -> 00/10/20..., 01H -> HH:00:00 */
    return ((rec_epoch_sec / cycle_sec) * cycle_sec);
